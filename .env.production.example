# ── Divido Chatbot — Production Environment Template ─────────────────────────
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Fill in every value marked with  ← CHANGE THIS
# 3. Never commit .env.production to Git

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db                            # Docker service name — do NOT change
DB_PORT=5432
DB_NAME=divido_chatbot
DB_USER=divido_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD    # ← CHANGE THIS

# ── AI Model ──────────────────────────────────────────────────────────────────
# Option A — Ollama (current, running on host machine)
USE_OPENAI=false
OLLAMA_BASE_URL=http://host.docker.internal:11434   # reaches host Ollama from container
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Option B — OpenAI (switch when ready for production speed)
# USE_OPENAI=true
# OPENAI_API_KEY=sk-...                # ← CHANGE THIS when switching
# OPENAI_MODEL=gpt-4o-mini

# ── Security ──────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD    # ← CHANGE THIS

# ── CORS — Divido website and app domains ─────────────────────────────────────
ALLOWED_ORIGINS=https://projectdivido.com,https://www.projectdivido.com,https://app.projectdivido.com

# ── Support Contact ───────────────────────────────────────────────────────────
SUPPORT_EMAIL=info@projectdivido.com
SUPPORT_PHONE=(+20) 1080 833686
